# === API Keys Configuration ===
# Copy this file to ".env" and replace the placeholder values
# with your actual API keys from the services listed below.

# OpenAI API key
# Generate here: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Polygon.io API key (financial market data)
# Generate here: https://polygon.io/dashboard/signup
POLYGON_API_KEY=your-polygon-api-key-here

# OpenWeatherMap API key (weather data)
# Generate here: https://home.openweathermap.org/api_keys
OPEN_WEATHER_API_KEY=your-openweather-api-key-here

# Tavily API key (web search)
# Generate here: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here
